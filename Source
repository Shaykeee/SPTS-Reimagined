                            leftBoundaryTime = nil
                            delayDuration = nil
                        end
                    else
                        -- Back inside boundary, reset delay
                        leftBoundaryTime = nil
                        delayDuration = nil
                    end
                end
            end)
        else
            boundaryCenter = nil
            boundaryPosition = nil
            lastBestZone = nil
            hasInitialized = false
            leftBoundaryTime = nil
            delayDuration = nil
            task.wait(0.1)
        end
    end
end)

