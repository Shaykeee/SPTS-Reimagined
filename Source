    end
end

local function formatNumber(value)
    if type(value) == "string" then
        value = tonumber(value) or 0
    end
    value = tonumber(value) or 0
    
    if value == 0 then return "0" end
    if value < 0 then return "-" .. formatNumber(-value) end
    -- i love stick 
    local abbreviations = {
        {1e51, "Sd"},
        {1e48, "Qnd"},
        {1e45, "Qd"},
        {1e42, "Td"},
        {1e39, "Dd"},
        {1e36, "Ud"},
        {1e33, "Dc"},
        {1e30, "No"},
        {1e27, "Oc"},
        {1e24, "Sp"},
        {1e21, "Sx"},
        {1e18, "Qi"},
        {1e15, "Qa"},
        {1e12, "T"},
        {1e9, "B"},
        {1e6, "M"},
        {1e3, "K"},
    }
    
    for _, pair in ipairs(abbreviations) do
        if value >= pair[1] then
            local formatted = value / pair[1]
            if formatted >= 100 then
                return string.format("%.0f%s", formatted, pair[2])
            else
                return string.format("%.2f%s", formatted, pair[2]):gsub("%.?0+([KMBTQaSxSpOctNonDec])$", "%1")
            end
        end
    end
    
    return tostring(math.floor(value))
end

local function getOneShotNPCs()
    local oneShotNPCs = {}
    local npcNameSet = {}
    for _, name in ipairs(npcNames) do
        npcNameSet[name] = true
    end
    
    -- Location 1: Check NPCs in Workspace root
    for _, obj in pairs(Workspace:GetChildren()) do
        if npcNameSet[obj.Name] then
            local humanoid = obj:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if canOneshot(humanoid.Health) then
                    table.insert(oneShotNPCs, { 
                        name = obj.Name, 
                        npc = obj, 
                        health = humanoid.Health,
                        maxHealth = humanoid.Health
                    })
                end
            end
        end
    end
    
    -- Location 2: Check NPCs in workspace.Main.EnemyNPCS.(npcName).(npcName)
    local mainFolder = Workspace:FindFirstChild("Main")
    if mainFolder then
        local enemyNPCSFolder = mainFolder:FindFirstChild("EnemyNPCS")
        if enemyNPCSFolder then
            for _, npcNameFolder in pairs(enemyNPCSFolder:GetChildren()) do
                if npcNameSet[npcNameFolder.Name] then
                    -- Find the NPC with matching name inside the folder
                    local npc = npcNameFolder:FindFirstChild(npcNameFolder.Name)
                    if npc then
                        local humanoid = npc:FindFirstChild("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            if canOneshot(humanoid.Health) then
                                table.insert(oneShotNPCs, { 
                                    name = npcNameFolder.Name, 
                                    npc = npc, 
                                    health = humanoid.Health,
                                    maxHealth = humanoid.Health
                                })
                            end
                        end
                    end
                end
            end
        end
    end
    
    return oneShotNPCs
end

local function getTargetNPCs()
    local oneShotNPCs = getOneShotNPCs()
    
    if npcOneshotMode == "Highest" then
        -- On first call, lock to the best tier available
        if npcBestTierLockedMaxHealth == nil and #oneShotNPCs > 0 then
            table.sort(oneShotNPCs, function(a, b)
                return a.maxHealth > b.maxHealth
            end)
            npcBestTierLockedMaxHealth = oneShotNPCs[1].maxHealth
        end
        
        -- Return ONLY NPCs matching the locked tier
        -- If no NPCs of that tier are alive, return empty and wait for respawn
        if npcBestTierLockedMaxHealth then
            local bestNPCs = {}
            for _, npcData in ipairs(oneShotNPCs) do
                if npcData.maxHealth == npcBestTierLockedMaxHealth then
                    table.insert(bestNPCs, npcData)
                end
            end
            return bestNPCs  -- Returns {} if none of locked tier are alive
        end
        return {}
    else
        return oneShotNPCs
    end
end

-- bible studies worth 97% of my life VERY IMPORTANT BOOK, DO NOT TOUCH
local function attackNPCs(targets)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local cooldownMultiplier = getCooldownMultiplier()

    for _, targetData in ipairs(targets) do
        -- Exit loop if toggle is disabled or cleanup is requested
        if not npcAutofarmToggleEnabled or npcAutofarmCleanupRequested then
            break
        end
        
        local npc = targetData.npc
        
        -- Keep attacking this NPC until it's dead
        while true do
            -- Exit immediately if toggle is disabled or cleanup is requested
            if not npcAutofarmToggleEnabled or npcAutofarmCleanupRequested then
                break
            end
            
            -- Check if NPC is still alive
            local humanoid = npc:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                break
            end
            
            local npcPosition = getNPCPosition(npc)
            if npcPosition then
                
                -- Store position before teleport if freeze is enabled
                local positionBeforeTeleport = hrp.CFrame
                
                -- Teleport logic based on attack type
                if npcAttackType == "Punch" then
                    -- For punch: teleport behind the NPC based on its facing direction (shorter distance)
                    local npcHumanoidRootPart = npc:FindFirstChild("HumanoidRootPart")
                    if npcHumanoidRootPart then
                        -- Get NPC's forward direction (negative Z)
                        local npcLookDirection = -npcHumanoidRootPart.CFrame.LookVector
                        local npcRightDirection = npcHumanoidRootPart.CFrame.RightVector
                        
                        -- Position 2 units behind the NPC (reduced from 5)
                        local behindPosition = npcPosition + (npcLookDirection * 2)
                        
                        -- Add small offset based on NPC's right direction (+1 or -1)
                        local offsetDirection = if npcRightDirection.X > 0 then 1 else -1
                        behindPosition = behindPosition + (npcRightDirection * offsetDirection)
                        
                        hrp.CFrame = CFrame.new(behindPosition, npcPosition)
                    else
                        -- Fallback if no HumanoidRootPart
                        local behindOffset = (hrp.Position - npcPosition).Unit * 2
                        hrp.CFrame = CFrame.new(npcPosition + behindOffset, npcPosition)
                    end
                else
                    -- For EnergySphere: teleport behind the NPC based on its facing direction (5 units distance)
                    local npcHumanoidRootPart = npc:FindFirstChild("HumanoidRootPart")
                    if npcHumanoidRootPart then
                        -- Get NPC's forward direction (negative Z)
                        local npcLookDirection = -npcHumanoidRootPart.CFrame.LookVector
                        local npcRightDirection = npcHumanoidRootPart.CFrame.RightVector
                        
                        -- Position 5 units behind the NPC
                        local behindPosition = npcPosition + (npcLookDirection * 5)
                        
                        -- Add small offset based on NPC's right direction (+1 or -1)
                        local offsetDirection = if npcRightDirection.X > 0 then 1 else -1
                        behindPosition = behindPosition + (npcRightDirection * offsetDirection)
                        
                        hrp.CFrame = CFrame.new(behindPosition, npcPosition)
                    else
                        -- Fallback if no HumanoidRootPart
                        local behindOffset = (hrp.Position - npcPosition).Unit * 5
                        hrp.CFrame = CFrame.new(npcPosition + behindOffset, npcPosition)
                    end
                end

                -- Check cleanup before fire wait
                if npcAutofarmCleanupRequested then break end

                local waitBeforeFire = npcAttackType == "Punch" and 0.05 or 0.2  -- Longer delay for EnergySphere to ensure teleport completes
                task.wait(waitBeforeFire)

                -- Check cleanup before firing attack
                if npcAutofarmCleanupRequested then break end

                -- Calculate remaining time: total loop time = cooldownMultiplier + 0.02s buffer
                local remainingTime = cooldownMultiplier - waitBeforeFire + 0.02

                -- Fire the selected attack type
                if npcAttackType == "Punch" then
                    local args = { "Punch" }
                    game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("UseSkill"):FireServer(unpack(args))
                else
                    local char = player.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        -- Fire downward from player's current feet position
                        local feetPosition = hrp.Position - Vector3.new(0, 3, 0)
                        local args = { "EnergySphere", Vector3.new(feetPosition.X, feetPosition.Y, feetPosition.Z) }
                        game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("UseSkill"):FireServer(unpack(args))
                    end
                end

                -- Check cleanup before cooldown wait
                if npcAutofarmCleanupRequested then break end

                task.wait(remainingTime)
            end
        end
    end
    
end

