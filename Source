local function getFistStrength()
    local fistStrength = player:GetAttribute("Fist strength")
    if fistStrength and fistStrength ~= 0 then
        if type(fistStrength) == "string" then
            fistStrength = tonumber(fistStrength) or 0
        end
        return fistStrength
    end
    
    fistStrength = player:GetAttribute("FistStrength")
    if fistStrength and fistStrength ~= 0 then
        if type(fistStrength) == "string" then
            fistStrength = tonumber(fistStrength) or 0
        end
        return fistStrength
    end
    
    local stats = player:FindFirstChild("Stats")
    if stats then
        local fistStat = stats:FindFirstChild("Fist Strength") or stats:FindFirstChild("FistStrength")
        if fistStat and fistStat:FindFirstChild("Value") then
            fistStrength = fistStat.Value.Value
            if fistStrength and fistStrength ~= 0 then return fistStrength end
        end
    end
    
    return 0
end

-- Get the player's cooldown multiplier for attack speed
local function getCooldownMultiplier()
    local cooldownMultiplier = player:GetAttribute("CooldownMultiplier")
    if cooldownMultiplier and cooldownMultiplier ~= 0 then
        if type(cooldownMultiplier) == "string" then
            cooldownMultiplier = tonumber(cooldownMultiplier) or 1
        end
        return cooldownMultiplier
    end
    return 1
end

-- Check if player can one-shot an NPC based on current damage
local function canOneshot(npcHealth)
    local fistStrength = getFistStrength()
    local multiplier = npcAttackType == "Punch" and DAMAGE_MULTIPLIER_PUNCH or DAMAGE_MULTIPLIER_ENERGYSPHERE
    local playerDamage = fistStrength * multiplier
    -- Require damage to be strictly greater than NPC health to guarantee one-shot
    return playerDamage > npcHealth
end

local function getNPCPosition(npc)
    if npc:IsA("Model") then
        return npc:GetPivot().Position
    elseif npc:IsA("BasePart") then
        return npc.Position
    end
    return nil
end

local function clearBlur()
