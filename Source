--[[ ==== STAT DETECTION HELPERS ==== ]]
-- These must be defined before the toggle callbacks use them

-- Convert scientific notation to full number
local function convertScientificNotation(value)
    if type(value) == "string" then
        value = tonumber(value) or 0
    end
    value = tonumber(value) or 0
    return value
end

local function getPlayerStat(statName)
    -- Try CamelCase variant first (FistStrength, BodyToughness, PsychicPower)
    local camelCaseNames = {
        ["Fist strength"] = "FistStrength",
        ["Body toughness"] = "BodyToughness",
        ["Psychic power"] = "PsychicPower"
    }
    
    local searchNames = {statName}
    if camelCaseNames[statName] then
        table.insert(searchNames, camelCaseNames[statName])
    end
    
    for _, name in ipairs(searchNames) do
        local stat = player:GetAttribute(name)
        if stat then
            if type(stat) == "string" then stat = tonumber(stat) or 0 end
            local converted = convertScientificNotation(stat)
            return converted
        end
    end
    
    local stats = player:FindFirstChild("Stats")
    if stats then
        for _, name in ipairs(searchNames) do
            local statObj = stats:FindFirstChild(name)
            if statObj and statObj:FindFirstChild("Value") then
                local converted = convertScientificNotation(statObj.Value.Value or statObj.Value or 0)
                return converted
            end
        end
    end
    return 0
end

--[[ ==== TRAINING ZONE FINDER FUNCTIONS ==== ]]
-- These must be defined before the toggle callbacks use them
local function findBestTrainingZone(stat, locations)
    stat = convertScientificNotation(stat)
    -- Iterate backwards (highest requirement first) to find best zone
    for index = #locations, 1, -1 do
        local zoneRequirement = locations[index][2]
        if type(zoneRequirement) == "string" then continue end
        if type(zoneRequirement) ~= "number" then continue end
        if stat >= zoneRequirement then
            return locations[index][1], zoneRequirement
        end
    end
    return locations[1][1], locations[1][2]
end

-- Find zone where player has 1/20th of the requirement (for death training)
local function findBestTrainingZoneDeathTraining(stat, locations)
    stat = convertScientificNotation(stat)
    -- Find zone where player has 1/20th of requirement
    for index = #locations, 1, -1 do
        local zoneRequirement = locations[index][2]
        if type(zoneRequirement) == "string" then continue end
        if type(zoneRequirement) ~= "number" then continue end
        if stat >= (zoneRequirement / 20) then
            return locations[index][1], zoneRequirement
        end
    end
    return locations[1][1], locations[1][2]
end

-- Find zone where player has 4x the requirement (for regular training)
local function findBestTrainingZoneRegular(stat, locations)
    stat = convertScientificNotation(stat)
    -- Find zone where player has 4x the requirement
    for index = #locations, 1, -1 do
        local zoneRequirement = locations[index][2]
        if type(zoneRequirement) == "string" then continue end
        if type(zoneRequirement) ~= "number" then continue end
        if stat >= (zoneRequirement * 4) then
            return locations[index][1], zoneRequirement
        end
    end
    return locations[1][1], locations[1][2]
end

