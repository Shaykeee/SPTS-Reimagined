        for _, race in ipairs(Options) do selectedRaces[race] = true end
    end,
}, "raceOptionsDropdown")

-- Reference to race roll UI elements
local raceLabel = player:WaitForChild("PlayerGui"):WaitForChild("RaceRollGui"):WaitForChild("Main"):WaitForChild("CurrentRaceLabel")
local tokensLabel = player:WaitForChild("PlayerGui"):WaitForChild("RaceRollGui"):WaitForChild("Main"):WaitForChild("RollTokensLabel")

local connection = nil
local isAutoRolling = false

--[[ ==== RACE ROLLING HELPER FUNCTIONS ==== ]]
-- Functions for reading race data and performing rolls

local function getCurrentRace()
    local success, result = pcall(function()
        if not raceLabel or not raceLabel.Parent then
            raceLabel = player:WaitForChild("PlayerGui"):WaitForChild("RaceRollGui"):WaitForChild("Main"):WaitForChild("CurrentRaceLabel")
        end
        local fullText = raceLabel.Text or "Unknown"
        return fullText:match("Current Race: ([%w%s]+) |") or fullText
    end)
    return success and result or "Unknown"
end

-- Get the number of roll tokens remaining
local function getRollTokens()
    local success, result = pcall(function()
        if not tokensLabel or not tokensLabel.Parent then
            tokensLabel = player:WaitForChild("PlayerGui"):WaitForChild("RaceRollGui"):WaitForChild("Main"):WaitForChild("RollTokensLabel")
        end
        local fullText = tokensLabel.Text or ""
        return tonumber(fullText:match("RollTokens: ([%d]+)")) or 0
    end)
    return success and result or 0
end

-- Perform a single race roll
local function rollRace()
    game:GetService("ReplicatedStorage"):WaitForChild("RollRaceRF"):InvokeServer()
end

-- Auto-roll until a desired race is found
local function startAutoRoll()
    local desiredRaces = {}
    for race, isSelected in pairs(selectedRaces) do
        if isSelected then table.insert(desiredRaces, race) end
    end

    local current = getCurrentRace()
    if selectedRaces[current] then
        Starlight:Notification({
            Title = "Roll Already Found!",
            Icon = NebulaIcons:GetIcon('dangerous', 'Material'),
            Content = "The Desired Roll " .. current .. " has already been rolled!",
        }, "INDEX")
        return
    end

    isAutoRolling = true
    local foundDesiredRoll = nil

    while isAutoRolling do
        current = getCurrentRace()

        if foundDesiredRoll then
            if selectedRaces[current] and current == foundDesiredRoll then
                task.wait(0.1)  
                continue
            else
                foundDesiredRoll = nil
            end
        end

        local tokens = getRollTokens()
        if tokens <= 0 then
            task.wait(1)
            continue
        end

        rollRace()
        task.wait()
        current = getCurrentRace()

        if selectedRaces[current] then
            task.spawn(function()
                Starlight:Notification({
                    Title = "Roll Found!",
                    Icon = NebulaIcons:GetIcon('sparkle', 'Material'),
                    Content = "The Desired Roll " .. current .. " has been rolled!",
                }, "INDEX")
            end)
            foundDesiredRoll = current
        end
    end
end

--[[ ==== RACE MONITORING FUNCTIONS ==== ]]
-- Monitor race changes and notify when a desired race is detected

local function startMonitoring()
    connection = raceLabel:GetPropertyChangedSignal("Text"):Connect(function()
        local current = getCurrentRace()
        if selectedRaces[current] then
            task.spawn(function()
                Starlight:Notification({
                    Title = "Roll Found!",
                    Icon = NebulaIcons:GetIcon('sparkle', 'Material'),
                    Content = "The Desired Roll " .. current .. " has been rolled!",
                }, "INDEX")
            end)
        end
    end)
end

-- Disconnect from race label monitoring
local function stopMonitoring()
    if connection then connection:Disconnect(); connection = nil end
end

