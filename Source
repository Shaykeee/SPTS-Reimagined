--[[ ==== AUTO CRATES LOOP ==== ]]
-- Task spawn for collecting crates automatically

task.spawn(function()
    while task.wait(0.3) do
        if cratesEnabled then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local crates = getAllCrates()
                if #crates > 0 then savedCFrame = hrp.CFrame end

                table.sort(crates, function(a, b)
                    return (a:GetPivot().Position - hrp.Position).Magnitude < (b:GetPivot().Position - hrp.Position).Magnitude
                end)

                local visited = {}
                local cratesCollected = false
                

                for _, crate in ipairs(crates) do
                    if not cratesEnabled then break end
                    if not visited[crate] then
                        visited[crate] = true
                        hrp.CFrame = crate:GetPivot() * CFrame.new(0, -3, 0)
                        task.wait(0.2)
                        forceInteract(crate)
                        cratesCollected = true
                        task.wait(0.3)
                    end
                end

                if cratesEnabled and savedCFrame and cratesCollected then
                    hrp.CFrame = savedCFrame
                end
            end)
        end
    end
end)


