--[[ ==== NPC COMBAT DETECTION ==== ]]
-- Check if there are living NPCs nearby that might be in combat
local function hasNearbyLivingNPCs(maxDistance)
    maxDistance = maxDistance or 100
    local char = player.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local npcNameSet = {}
    for _, name in ipairs(npcNames) do
        npcNameSet[name] = true
    end
    
    for _, obj in pairs(Workspace:GetChildren()) do
        if npcNameSet[obj.Name] then
            local humanoid = obj:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local distance = (obj.Position - hrp.Position).Magnitude
                if distance <= maxDistance then
                    return true
                end
            end
        end
    end
    
    return false
end

