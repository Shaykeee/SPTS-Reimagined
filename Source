-- Hero and villain status mappings
local heroStatuses = {"Protector", "Guardian", "Superhero", "Defender", "Crusader", "Archangel"}
local villainStatuses = {"Lawbreaker", "Criminal", "Supervillain", "Karama", "Revenge", "Chaos"}

local function isHeroStatus(status)
    for _, heroStatus in ipairs(heroStatuses) do
        if status == heroStatus then return true end
    end
    return false
end

local function isVillainStatus(status)
    for _, villainStatus in ipairs(villainStatuses) do
        if status == villainStatus then return true end
    end
    return false
end

-- Get a player's status from leaderstats
local function getPlayerStatus(targetPlayer)
    if not targetPlayer then 
        return nil 
    end
    
    local leaderstats = targetPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local status = leaderstats:FindFirstChild("Status")
        if status then
            local statusValue = status.Value
            return statusValue
        end
    end
    return nil
end

