--[[ ==== STAT DETECTION & TRAINING HELPERS ==== ]]
-- Functions for detecting player stats and finding appropriate training zones

-- Note: convertScientificNotation and getPlayerStat moved earlier in script (before stat toggle callbacks)

-- Get a target player's attribute by name  
local function getTargetPlayerStat(targetPlayer, statName)
    -- Try CamelCase variant first (FistStrength, BodyToughness, PsychicPower)
    local camelCaseNames = {
        ["Fist strength"] = "FistStrength",
        ["Body toughness"] = "BodyToughness",
        ["Psychic power"] = "PsychicPower"
    }
    
    local searchNames = {statName}
    if camelCaseNames[statName] then
        table.insert(searchNames, camelCaseNames[statName])
    end
    
    for _, name in ipairs(searchNames) do
        local stat = targetPlayer:GetAttribute(name)
        if stat then
            if type(stat) == "string" then stat = tonumber(stat) or 0 end
            local converted = convertScientificNotation(stat)
            return converted
        end
    end
    
    local stats = targetPlayer:FindFirstChild("Stats")
    if stats then
        for _, name in ipairs(searchNames) do
            local statObj = stats:FindFirstChild(name)
            if statObj and statObj:FindFirstChild("Value") then
                local converted = convertScientificNotation(statObj.Value.Value or statObj.Value or 0)
                return converted
            end
        end
    end
    return 0
end

-- Teleport player in front of main player
local function teleportPlayerInFront(targetPlayer, mainPlayer)
    -- Find models in workspace
    local targetModel = Workspace:FindFirstChild(targetPlayer.Name)
    local mainModel = Workspace:FindFirstChild(mainPlayer.Name)
    
    if not targetModel then
        return
    end
    
    local targetHRP = targetModel:FindFirstChild("HumanoidRootPart")
    local mainHRP = mainModel:FindFirstChild("HumanoidRootPart")
    
    if not targetHRP then
        return
    end
    if not mainHRP then
        return
    end
    
    -- Get main player's forward direction
    local forwardDirection = mainHRP.CFrame.LookVector
    local newPosition = mainHRP.Position + forwardDirection * 1
    
    -- Preserve target's current rotation while changing position
    local rotationOffset = targetHRP.CFrame - targetHRP.CFrame.Position
    targetHRP.CFrame = CFrame.new(newPosition) * rotationOffset
end
