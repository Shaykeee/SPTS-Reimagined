local function formatNumber(value)
    if type(value) == "string" then
        value = tonumber(value) or 0
    end
    value = tonumber(value) or 0
    if value == 0 then return "0" end
    if value < 0 then return "-" .. formatNumber(-value) end
    local abbreviations = {
        {1e51, "Sd"},
        {1e48, "Qnd"},
        {1e45, "Qd"},
        {1e42, "Td"},
        {1e39, "Dd"},
        {1e36, "Ud"},
        {1e33, "Dc"},
        {1e30, "No"},
        {1e27, "Oc"},
        {1e24, "Sp"},
        {1e21, "Sx"},
        {1e18, "Qi"},
        {1e15, "Qa"},
        {1e12, "T"},
        {1e9, "B"},
        {1e6, "M"},
        {1e3, "K"},
    }
    for _, pair in ipairs(abbreviations) do
        if value >= pair[1] then
            local formatted = value / pair[1]
            if formatted >= 100 then
                return string.format("%.0f%s", formatted, pair[2])
            else
                return string.format("%.2f%s", formatted, pair[2]):gsub("%.?0+([KMBTQaSxSpOctNonDec])$", "%1")
            end
        end
    end
    return tostring(math.floor(value))
end
